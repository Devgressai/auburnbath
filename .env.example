# Copy this file to `.env.local` and fill in. .env.local is gitignored.

# Resend — used by /contact form to email the lead to the team.
# 1. Sign up at https://resend.com (or reuse your existing Oakwood account).
# 2. Make sure oakwoodremodel.com is added + verified as a sending domain
#    in your Resend dashboard. (No need to verify auburnbath.com — we send
#    from the Oakwood domain by default.)
# 3. Create an API key with "Send emails" scope.
# 4. Paste it below.
# If RESEND_API_KEY is empty, submissions log to the server console
# instead of emailing (so the form keeps working in development).
RESEND_API_KEY=

# Optional override of the From address. Must be on a verified domain
# in your Resend account. Defaults to "Auburn Bath <info@oakwoodremodel.com>".
RESEND_FROM=
